# Webness Local Brain
# Copy to .env on the AI PC and set a long random BRAIN_API_KEY before exposing the tunnel.

BRAIN_HOST=127.0.0.1
BRAIN_PORT=8000
BRAIN_API_KEY=CHANGE_ME_SHARED_SECRET_BETWEEN_VPS_AND_LOCAL
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional Cloudflare Access service-token validation.
# If set, callers must include matching CF-Access-Client-Id and CF-Access-Client-Secret headers.
CLOUDFLARE_ACCESS_CLIENT_ID=
CLOUDFLARE_ACCESS_CLIENT_SECRET=

# Model routing from BRAIN_AI_DEPLOYMENT_PLAN.md
BRAIN_MODEL_CODE=qwen2.5-coder:7b
BRAIN_MODEL_REASONING=deepseek-r1:8b
BRAIN_MODEL_GENERAL=qwen2.5:7b
BRAIN_MODEL_POLISH=gemma2:9b
BRAIN_MODEL_EMBEDDINGS=nomic-embed-text
BRAIN_RESEARCH_MAX_ITERATIONS=4
BRAIN_RESEARCH_CONFIDENCE_THRESHOLD=0.85
