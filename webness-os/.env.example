# ============================================
# WEBNESS OS - Environment Variables
# ============================================
# Copy this file to .env and fill in values.
# Never commit real API keys, tokens, phrases, or client secrets.

# ---- Database (PostgreSQL + pgvector) ----
DATABASE_URL="postgresql://webness:CHANGE_ME@localhost:5432/webness_os?schema=public&connection_limit=5"

# ---- Redis (BullMQ) ----
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# ---- JWT Auth ----
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING"
JWT_REFRESH_SECRET="CHANGE_ME_TO_ANOTHER_RANDOM_64_CHAR_STRING"

# ---- AI Brain / Hermes / Local Models ----
CLOUD_FALLBACK=true
BRAIN_URL="http://127.0.0.1:8000"
BRAIN_API_URL="http://127.0.0.1:8000"
BRAIN_API_KEY="CHANGE_ME_SHARED_SECRET_BETWEEN_API_AND_LOCAL_BRAIN"
HERMES_ENABLED=false
HERMES_MODEL="nous-hermes2:latest"
OLLAMA_BASE_URL="http://localhost:11434"

# ---- Parallel AI Council Cloud Providers ----
GROQ_API_KEY=""
GROQ_DEFAULT_MODEL="llama-3.3-70b-versatile"
OPENROUTER_API_KEY=""
OPENROUTER_DEFAULT_MODEL="meta-llama/llama-3.1-8b-instruct:free"
GOOGLE_AI_STUDIO_KEY=""
GEMINI_DEFAULT_MODEL="gemini-2.5-flash"
OPENAI_API_KEY=""
OPENAI_DEFAULT_MODEL="gpt-4o-mini"

# ---- Local App Connectors ----
JAN_API_BASE_URL=""
JAN_API_KEY=""
JAN_DEFAULT_MODEL="llama3.1:8b"
CLAUDE_CODE_BIN=""
CODEX_BIN=""
ANTIGRAVITY_PATH=""
OBSIDIAN_VAULT_PATH=""

# ---- Admin ----
SUPER_ADMIN_EMAIL="admin@webness.in"
ADMIN_IP_ALLOWLIST="127.0.0.1"

# ---- Payments ----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ---- WhatsApp Cloud API ----
WHATSAPP_APP_SECRET=""
WHATSAPP_VERIFY_TOKEN="CHANGE_ME_WEBHOOK_VERIFY_TOKEN"

# ---- External APIs ----
SERPER_API_KEY=""
RESEND_API_KEY=""
GOOGLE_PAGESPEED_API_KEY=""

# ---- Cloudflare R2 ----
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="webness-assets"
R2_PUBLIC_URL=""

# ---- Application ----
NODE_ENV="development"
PORT=3001
CORS_ORIGIN="http://localhost:3000,http://localhost:3003"
PUBLIC_APP_URL="http://localhost:3000"
LOG_LEVEL="debug"
